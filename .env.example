# .env.example
# Copy this file to .env and fill in your credentials
# NEVER commit .env to GitHub

# Weights & Biases (get from https://wandb.ai/authorize)
WANDB_API_KEY=your_key_here

# CDS API for ERA5 climate data (get from https://cds.climate.copernicus.eu/profile)
# Store in ~/.cdsapirc file - see README for format
CDS_API_KEY=your_key_here

# NASA Earthdata (for Landsat via USGS)
# Register at https://urs.earthdata.nasa.gov
EARTHDATA_USERNAME=your_username_here
EARTHDATA_PASSWORD=your_password_here